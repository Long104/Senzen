# ============================================================
# Senzen Terraform Variables
# Copy this file to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars
# ============================================================

# Terraform Cloud
tfc_organization = "your-tfc-org-name"
tfc_workspace    = "senzen-production"

# Vercel
vercel_api_token = "vercel-api-token-here"

# Cloudflare
cloudflare_api_token           = "cloudflare-api-token-here"
cloudflare_account_id          = "your-cloudflare-account-id"
cloudflare_workers_script_name = "senzen-backend"
# Optional: bind a custom domain to the Worker
# cloudflare_zone_id       = "your-zone-id"
# cloudflare_custom_domain = "api.example.com"

# GitHub
github_repo = "Long104/Senzen"

# Supabase PostgreSQL
db_host     = "db.supabase-ref.supabase.co"
db_port     = "5432"
db_user     = "postgres"
db_password = "your-supabase-db-password"
db_name     = "postgres"

# Auth & Security
jwt_secret_key       = "your-random-jwt-secret"
google_client_id     = "your-google-client-id"
google_client_secret = "your-google-client-secret"
github_client_id     = "your-github-client-id"
github_client_secret = "your-github-client-secret"
