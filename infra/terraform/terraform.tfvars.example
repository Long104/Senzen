# ============================================================
# Senzen Terraform Variables
# Copy this file to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars
# ============================================================

# Terraform Cloud
tfc_organization = "your-tfc-org-name"
tfc_workspace    = "senzen-production"

# Vercel
vercel_api_token = "vercel-api-token-here"

# GitHub
github_repo = "Long104/Senzen"

# Backend (SnapDeploy)
# Set this after creating the container on SnapDeploy dashboard.
# Format: https://<container-name>.containers.snapdeploy.dev
snapdeploy_backend_url = "https://senzen-backend.containers.snapdeploy.dev"

# ─────────────────────────────────────────────────────────────
# Backend env vars are set in the SnapDeploy dashboard, NOT
# here. See backend-deploy.yml for the full list:
#   DB_HOST, DB_PORT, DB_USER, DB_PASSWORD, DB_NAME
#   jwtSecretKey
#   GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET
#   GITHUB_CLIENT_ID, GITHUB_CLIENT_SECRET
#   FRONTEND_URL
# ─────────────────────────────────────────────────────────────
